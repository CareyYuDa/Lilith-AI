# Remote helper model used by memory tasks and auxiliary requests.
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://opencode.ai/zen/go/v1
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# Local LM Studio / OpenAI-compatible model for the lilith mode.
LOCAL_BASE_URL=http://127.0.0.1:1234/v1
LOCAL_MODEL=qwen3.5-9b
LOCAL_API_KEY=lm-studio

# Remote model for the lili mode.
LILI_API_KEY=your_api_key_here
LILI_BASE_URL=https://opencode.ai/zen/go/v1
LILI_MODEL=deepseek-v4

# Optional Open WebUI Channel push integration.
OPENWEBUI_BASE_URL=http://localhost:8080
OPENWEBUI_API_KEY=
LILITH_CHANNEL_NAME=莉莉丝的房间
